{
  "name": "@cycove/backend",
  "private": true,
  "version": "0.0.0",
  "description": "CyCove relay backend — dumb pipe only, no cryptography, no plaintext. Contract: ../docs/api/openapi.yaml and ../docs/api/asyncapi.yaml. Trust boundary this code has to respect: ../THREAT_MODEL.md.",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "postinstall": "prisma generate",
    "db:migrate": "prisma migrate dev"
  },
  "dependencies": {
    "@fastify/cors": "^11.3.0",
    "@fastify/websocket": "^11.0.0",
    "@prisma/client": "^6.0.0",
    "fastify": "^5.0.0",
    "ioredis": "^5.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.0",
    "prisma": "^6.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
